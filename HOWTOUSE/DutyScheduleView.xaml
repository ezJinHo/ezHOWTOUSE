<UserControl x:Class="HOWTOUSE.DutyScheduleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D8E0EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="26" />
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource Panel}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Content="‹" Width="38" Height="38" Background="Transparent" BorderThickness="0" FontSize="24" Click="PreviousMonthButton_Click" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <ComboBox x:Name="MonthComboBox" Width="180" SelectionChanged="CalendarSelectionChanged" />
                    <ComboBox x:Name="YearComboBox" Width="180" Margin="12,0,0,0" SelectionChanged="CalendarSelectionChanged" />
                </StackPanel>
                <Button Grid.Column="2" Content="›" Width="38" Height="38" Background="Transparent" BorderThickness="0" FontSize="24" Click="NextMonthButton_Click" />
            </Grid>

            <UniformGrid Grid.Row="1" Columns="7" Margin="80,22,80,8">
                <TextBlock Text="Su" HorizontalAlignment="Center" Foreground="#8A8F98" />
                <TextBlock Text="Mo" HorizontalAlignment="Center" Foreground="#8A8F98" />
                <TextBlock Text="Tu" HorizontalAlignment="Center" Foreground="#8A8F98" />
                <TextBlock Text="We" HorizontalAlignment="Center" Foreground="#8A8F98" />
                <TextBlock Text="Th" HorizontalAlignment="Center" Foreground="#8A8F98" />
                <TextBlock Text="Fr" HorizontalAlignment="Center" Foreground="#8A8F98" />
                <TextBlock Text="Sa" HorizontalAlignment="Center" Foreground="#8A8F98" />
            </UniformGrid>

            <ItemsControl x:Name="CalendarItemsControl" Grid.Row="2" Margin="80,0,80,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="7" Rows="6" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="48" Height="42" CornerRadius="8" Margin="4" Background="{Binding Background}" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding DayText}" Foreground="{Binding Foreground}" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</UserControl>
